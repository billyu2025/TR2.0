# 限流配置示例：复制所需行到 .env，或按需修改默认值（见 tr_fill_in_api.py 中 RATE_LIMIT_*）
# 多条件用英文逗号或分号分隔，如：300 per hour, 5000 per day
# 语法与 Flask-Limiter 一致：https://flask-limiter.readthedocs.io/

# 全站默认（未单独限流的路由仍受此约束；按客户端 IP）
RATE_LIMIT_GLOBAL=600 per hour, 12000 per day

# 存储：单进程用 memory://；多 worker 建议 Redis，例如 redis://127.0.0.1:6379
RATE_LIMIT_STORAGE_URI=memory://

# 登录（防暴力猜密码）
RATE_LIMIT_LOGIN=5 per minute

# 管理：建用户 / 重置密码
RATE_LIMIT_ADMIN_CREATE_USER=10 per hour
RATE_LIMIT_ADMIN_RESET_PASSWORD=3 per hour

# 批量下载、异步下载任务创建、Stockist 批量接口等
RATE_LIMIT_HEAVY_POST=30 per minute

# 单文件下载类 GET（PDF、Stockist 单包、任务 ZIP）
RATE_LIMIT_DOWNLOAD_GET=120 per minute

# 创建 PDF 生成任务
RATE_LIMIT_PDF_GENERATE=45 per minute

# 系统级重操作：全表更新、索引重建/清理、Orders_gen_pdf 再生等
RATE_LIMIT_SYSTEM_POST=5 per hour
